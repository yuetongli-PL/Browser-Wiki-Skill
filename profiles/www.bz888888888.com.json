{
  "host": "www.bz888888888.com",
  "archetype": "chapter-content",
  "schemaVersion": 1,
  "primaryArchetype": "chapter-content",
  "version": 1,
  "ocr": {
    "enabled": true,
    "required": true,
    "engine": "tesseract",
    "command": "tesseract",
    "languages": "chi_sim+eng",
    "pageSegmentationMode": 6,
    "timeoutSeconds": 15,
    "preserveImagePlaceholders": true,
    "imageSourceAttributes": [
      "data-src",
      "data-original",
      "data-url",
      "src"
    ],
    "textAttributes": [
      "data-ocr-text",
      "data-text",
      "alt",
      "title"
    ]
  },
  "search": {
    "formSelectors": [
      "form[action*=\"search\"]",
      "form[action*=\"/s/\"]",
      "form[action*=\"/ss/\"]",
      "form[action*=\"modules/article/search.php\"]"
    ],
    "inputSelectors": [
      "input[name=\"searchkey\"]",
      "input[name=\"q\"]",
      "input[name=\"keyword\"]",
      "input[name=\"search\"]",
      "input[type=\"search\"]"
    ],
    "submitSelectors": [
      "button[type=\"submit\"]",
      "input[type=\"submit\"]",
      ".search-btn",
      "#search_btn"
    ],
    "resultTitleSelectors": [
      "title",
      "h1",
      ".search-title",
      ".layout-tit"
    ],
    "resultBookSelectors": [
      "a[href*=\"/book/\"]",
      "a[href*=\"/novel/\"]",
      "a[href*=\"/txt/\"]",
      "a[href*=\"/biqu\"]",
      ".txt-list a[href]",
      ".book-list a[href]"
    ],
    "queryParamNames": [
      "q",
      "keyword",
      "searchkey",
      "search"
    ],
    "requestCandidates": [
      {
        "method": "POST",
        "path": "/ss/",
        "data": {
          "searchkey": "{query}"
        }
      },
      {
        "method": "GET",
        "path": "/modules/article/search.php",
        "query": {
          "searchkey": "{query}"
        }
      },
      {
        "method": "GET",
        "path": "/search/",
        "query": {
          "searchkey": "{query}"
        }
      }
    ],
    "defaultQueries": [],
    "knownQueries": []
  },
  "bookDetail": {
    "authorMetaNames": [
      "og:novel:author",
      "author"
    ],
    "authorLinkMetaNames": [
      "og:novel:author_link"
    ],
    "latestChapterNameMetaNames": [
      "og:novel:latest_chapter_name",
      "og:novel:lastest_chapter_name"
    ],
    "latestChapterMetaNames": [
      "og:novel:latest_chapter_url",
      "og:novel:lastest_chapter_url"
    ],
    "updateTimeMetaNames": [
      "og:novel:update_time",
      "lastmod"
    ],
    "bookUrlPatterns": [
      "/(?:book|novel|txt|b|biqu)\\d*/?\\d*/?$",
      "/\\d+/?$"
    ],
    "chapterUrlPatterns": [
      "/(?:book|novel|txt|b|biqu)?\\d+/\\d+(?:_\\d+)?\\.html$"
    ],
    "chapterLinkSelectors": [
      "#list a[href]",
      ".listmain a[href]",
      ".chapter-list a[href]",
      ".volume a[href]",
      "dd a[href]"
    ],
    "directoryLinkSelectors": [
      "#list a[href]",
      ".listmain a[href]",
      ".chapter-list a[href]",
      ".section-list a[href]",
      "dd a[href]"
    ],
    "directoryPageUrlTemplate": "{detail_url}{page}/",
    "directoryPageStart": 1,
    "directoryPageMax": 32,
    "directoryMinimumExpected": 20
  },
  "chapter": {
    "contentSelectors": [
      "#content",
      ".content",
      ".chapter-content",
      ".read-content",
      ".reader-main .content",
      "article"
    ],
    "titleSelectors": [
      ".reader-main .title",
      ".chapter-title",
      ".content_read h1",
      "h1.title",
      "h1",
      "title"
    ],
    "prevSelector": "a[rel=\"prev\"], #prev_url, .prev a[href], .prev-chapter a[href]",
    "nextSelector": "a[rel=\"next\"], #next_url, .next a[href], .next-chapter a[href]",
    "cleanupPatterns": [
      "上一章",
      "下一章",
      "返回目录",
      "加入书签",
      "章节报错",
      "推荐票",
      "请收藏本站",
      "最新网址",
      "手机用户请浏览",
      "纯文字在线阅读本站域名"
    ]
  }
}

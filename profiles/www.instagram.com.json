  "social": {
    "defaultOutputRoot": "instagram-downloads",
    "requiresLogin": true,
    "supportedActions": [
      "account-info",
      "profile-content",
      "profile-following",
      "profile-followers",
      "followed-users",
      "followed-posts-by-date",
      "search",
      "full-archive",

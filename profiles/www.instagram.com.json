      "resume-after-cooldown",
      "media-fast-download",
      "health-check",
      "live-acceptance-report",
      "kb-refresh"
    ],
    "naturalLanguage": {
      "siteAliases": [
        "instagram",
        "ig",
        "insta",
        "www.instagram.com"
      ],
      "intentAliases": {
        "full-archive": [
          "full archive",
          "deep archive",
          "export all posts",
          "全量归档",
          "全量抓取",
          "完整导出"
        ],
        "resume-full-archive": [
          "resume full archive",
          "continue full archive",
          "continue from cursor",
          "全量续跑",
          "继续全量归档",
          "从上次位置继续"
        ],
        "resume-after-cooldown": [
          "resume after cooldown",
          "continue after rate limit",
          "retry after cooldown",
          "限流冷却后继续",
          "冷却结束继续",
          "等限流恢复后续跑"
        ],
        "media-fast-download": [
          "fast media download",
          "high speed media download",
          "download media fast",
          "媒体高速下载",
          "高速下载图片视频",
          "快速下载媒体"
        ],
        "health-check": [
          "health check",
          "session health",
          "auth health check",
          "健康检查",
          "登录健康检查",
          "检查会话状态"
        ],
        "live-acceptance-report": [
          "live acceptance report",
          "live verification report",
          "acceptance report",
          "live 验收报告",
          "验收报告",
          "现场验证报告"
        ],
        "kb-refresh": [
          "kb refresh",
          "knowledge base refresh",
          "refresh scenario kb",
          "KB 刷新",
          "知识库刷新",
          "刷新场景知识库"
        ]
      },
      "phraseMappings": [
        {
          "phrases": [
            "把 IG 账号 <handle> 全量续跑",
            "继续跑 instagram <handle> 的全量归档",
            "resume Instagram full archive for <handle>"
          ],
          "intent": "resume-full-archive"
        },
        {
          "phrases": [
            "Instagram 限流冷却后继续",
            "rate limit cooled down, continue IG",
            "等 IG 冷却后续跑"
          ],
          "intent": "resume-after-cooldown"
        },
        {
          "phrases": [
            "高速下载 <handle> 的 IG 媒体",
            "Instagram media fast download for <handle>",
            "快速下载 IG 图片视频"
          ],
          "intent": "media-fast-download"
        },
        {
          "phrases": [
            "检查 Instagram 登录健康",
            "IG health check",
            "检查 Instagram 会话状态"
          ],
          "intent": "health-check"
        },
        {
          "phrases": [
            "生成 Instagram live 验收报告",
            "run IG live acceptance report",
            "Instagram 现场验证报告"
          ],
          "intent": "live-acceptance-report"
        },
        {
          "phrases": [
            "刷新 Instagram KB",
            "IG scenario KB refresh",
            "刷新 Instagram 场景知识库"
          ],
          "intent": "kb-refresh"
        }
      ],
      "commandMappings": {
        "resume-full-archive": "node src/entrypoints/sites/instagram-action.mjs profile-content <handle> --content-type posts --full-archive --run-dir <previous-or-new-run>",
        "resume-after-cooldown": "node src/entrypoints/sites/instagram-action.mjs profile-content <handle> --content-type posts --full-archive --risk-backoff-ms <ms> --risk-retries <n>",
        "media-fast-download": "node src/entrypoints/sites/instagram-action.mjs profile-content <handle> --content-type media --download-media --max-media-downloads <n>",
        "health-check": "node scripts/social-auth-recover.mjs --execute --site instagram --verify",
        "live-acceptance-report": "node scripts/social-live-verify.mjs --execute --site instagram --ig-account <handle>",
        "kb-refresh": "node scripts/social-kb-refresh.mjs --execute --site instagram --ig-account <handle>"
      }
    },
    "contentTypes": [
      "posts",
      "reels",
      "media",
      "highlights"
    ],
    "urlTemplates": {
      "profile": "https://www.instagram.com/{account}/",
      "posts": "https://www.instagram.com/{account}/",
      "reels": "https://www.instagram.com/{account}/reels/",
      "media": "https://www.instagram.com/{account}/",
      "highlights": "https://www.instagram.com/{account}/",
      "following": "https://www.instagram.com/{account}/following/",
      "followers": "https://www.instagram.com/{account}/followers/",
      "search": "https://www.instagram.com/explore/search/?q={query}"
    },
    "selectors": {
      "postItems": "article, main a[href^=\"/p/\"], main a[href^=\"/reel/\"], main a[href^=\"/tv/\"]",
      "postText": "h1, span, div",
      "postLinks": "a[href^=\"/p/\"], a[href^=\"/reel/\"], a[href^=\"/tv/\"]",
      "timestamps": "time[datetime]",
      "media": "img, video, source",
      "currentProfileLink": "a[href^=\"/\"][role=\"link\"]",
      "accountName": "header h1, header h2, h1",
      "accountBio": "header section, header",
      "relationLinks": "a[href^=\"/\"][role=\"link\"]"
    },
    "followedFeed": {
      "route": "https://www.instagram.com/",
      "dateFilterMode": "followed-profile-date-scan"
    },
    "archive": {
      "defaultStrategy": "api-cursor-with-dom-fallback",
      "followedDateStrategy": "following-dialog-profile-detail-scan",
      "apiEndpointPatterns": [
        "/graphql/query",
        "/api/graphql",
        "/api/v1/feed",
        "/api/v1/media",
        "/api/v1/users"
      ],
      "fallbackStrategy": "deep-dom-scroll-with-detail-date-verification",
      "completenessBoundedBy": [
        "dialog following pagination",
        "profile visibility",
        "detail page timestamp availability",
        "maxUsers",
        "maxItems"
      ]
    }
